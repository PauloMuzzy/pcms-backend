# Application
NODE_ENV=development
PORT=3000
APP_NAME=PCMS Backend

# Database (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=pcms_user
DB_PASSWORD=pcms_password
DB_DATABASE=pcms_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
